programa {
  funcao inicio() {
    real total 
    real pesoPrato 
    real precoPorKg

    escreva("Peso em kg do prato: ")
    leia(pesoPrato)

    escreva("Valor do kg: ")
    leia(precoPorKg)    

  total = pesoPrato * precoPorKg

  escreva("O preço do prato é : R$ ", total)

    
  }
}

















































